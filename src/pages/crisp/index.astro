---
import Layout from "../../layouts/Layout.astro";
import { config } from "../../config";
---

<Layout title="Crisp — sharper AI output, no slop" description="A free browser extension by Votting Group. Crisp makes ChatGPT, Claude, Copilot, and Perplexity write like a real professional. Estonian-first. 100% private.">

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-grid">
    <div class="glow-orb w-[500px] h-[500px] bg-[var(--color-accent)] top-[-150px] left-1/2 -translate-x-1/2 opacity-[0.06]"></div>
    <div class="glow-orb w-[350px] h-[350px] bg-[var(--color-gold)] bottom-[-100px] right-[-80px] opacity-[0.06]"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal mb-8 visible">
        <span class="inline-block text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-text-muted)] border border-[var(--color-border-light)] rounded-full px-5 py-2">
          A Võtting Grupp product · Free · Chrome + Edge
        </span>
      </div>

      <h1 class="reveal reveal-delay-1 font-serif text-5xl md:text-7xl lg:text-8xl font-medium leading-[1.05] tracking-tight max-w-4xl mx-auto visible">
        <span class="gradient-text">Sharper AI output.</span><br>
        <span class="text-[var(--color-text-primary)]">No slop.</span>
      </h1>

      <p class="reveal reveal-delay-2 mt-8 text-lg md:text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed font-light visible">
        A browser extension that makes ChatGPT, Claude, Copilot, and Perplexity write like a real professional.
        No em-dashes, no emoji, no "I'd be happy to help". Estonian-first. 100% private.
      </p>

      <div class="reveal reveal-delay-3 mt-12 flex flex-col sm:flex-row gap-4 justify-center visible">
        <a href="#install" class="group inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium tracking-wide transition-all hover:shadow-lg hover:scale-[1.02]">
          Install Crisp
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-[var(--color-border-light)] text-[var(--color-text-secondary)] text-sm font-medium tracking-wide transition-all hover:border-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]">
          See how it works
        </a>
      </div>
    </div>
  </section>

  <!-- Before / After -->
  <section id="how-it-works" class="relative py-24 border-t border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-12">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">The difference</span>
        <h2 class="font-serif text-3xl md:text-5xl font-medium leading-tight">What Crisp actually does</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div class="reveal reveal-delay-1 p-7 rounded-xl bg-white border border-[var(--color-border)] shadow-sm">
          <span class="text-[10px] tracking-wider uppercase font-medium px-2.5 py-1 rounded-full bg-red-50 text-red-600">× ChatGPT</span>
          <p class="mt-5 text-[15px] leading-relaxed text-[var(--color-text-secondary)] whitespace-pre-line">Certainly! I'd be happy to delve into this comprehensively — it's worth noting that this will not only streamline your workflow but also revolutionize your productivity. 🚀

Hope this helps!</p>
        </div>
        <div class="reveal reveal-delay-2 p-7 rounded-xl bg-white border border-[var(--color-border)] border-glow shadow-sm">
          <span class="text-[10px] tracking-wider uppercase font-medium px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-600">✓ ChatGPT + Crisp</span>
          <p class="mt-5 text-[15px] leading-relaxed text-[var(--color-text-primary)]">Here's the plan. This will streamline your workflow and change your productivity.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] bg-noise">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-14">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">Features</span>
        <h2 class="font-serif text-3xl md:text-5xl font-medium">Every detail tuned for business</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { title: "40+ anti-slop rules", body: "Strips em-dashes, 'not only but also', 'delve', 'leverage', 'utilize', 'comprehensive', emoji decorations." },
          { title: "Estonian business register", body: "Proper cases, no English leakage, no 'tänapäeva kiires maailmas' filler. Formal but natural." },
          { title: "One-click tasks", body: "Write email, reply, summarize, translate, shorten, polish. No prompt engineering required." },
          { title: "Six profiles", body: "Business email, LinkedIn post, customer reply, meeting summary, free chat. Switch in one click." },
          { title: "Company brain", body: "Paste brand voice, sample emails, terminology. Crisp appends it invisibly to every prompt." },
          { title: "Regex banned phrases", body: "Add your own blocklist with full regex support. Each match disappears from every response." },
          { title: "Right-click tasks", body: "Select text anywhere, right-click, pick a Crisp task. Works alongside the floating toolbar." },
          { title: "Live preview", body: "Paste AI output in settings, see exactly what Crisp cleans, before it touches your real work." },
          { title: "Import / export", body: "Back up all settings as JSON. Move them between devices or share your company's config with the team." },
        ].map((f, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} p-7 rounded-xl bg-white border border-[var(--color-border)] border-glow shadow-sm`}>
            <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-2">{f.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="py-24 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-12">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-gold)] mb-4 block">Works with</span>
        <h2 class="font-serif text-3xl md:text-4xl font-medium">Every major AI tool</h2>
        <p class="mt-4 text-[var(--color-text-secondary)] max-w-xl mx-auto leading-relaxed">One install, one settings page, four AI services. Use whichever tool your team already pays for.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {[
          { name: "ChatGPT", host: "chatgpt.com" },
          { name: "Claude", host: "claude.ai" },
          { name: "Copilot", host: "copilot.microsoft.com" },
          { name: "Perplexity", host: "perplexity.ai" },
        ].map((p, i) => (
          <div class={`reveal reveal-delay-${i + 1} p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-center`}>
            <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium mb-2">{p.host}</div>
            <div class="text-xl font-serif font-medium text-[var(--color-text-primary)]">{p.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-12">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">Privacy by design</span>
        <h2 class="font-serif text-3xl md:text-5xl font-medium leading-tight">100% private.<br>No server. No account.</h2>
        <p class="mt-5 text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
          Every setting stays in your browser. Your prompts go directly to your chosen AI provider — never through us, because there is no "us" server.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <div class="reveal reveal-delay-1 p-8 rounded-xl bg-white border border-[var(--color-border)] text-center">
          <div class="font-serif text-5xl font-medium text-[var(--color-text-primary)] mb-2">0</div>
          <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium">Servers we run</div>
        </div>
        <div class="reveal reveal-delay-2 p-8 rounded-xl bg-white border border-[var(--color-border)] text-center">
          <div class="font-serif text-5xl font-medium text-[var(--color-text-primary)] mb-2">0</div>
          <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium">Analytics trackers</div>
        </div>
        <div class="reveal reveal-delay-3 p-8 rounded-xl bg-white border border-[var(--color-border)] text-center">
          <div class="font-serif text-5xl font-medium text-[var(--color-text-primary)] mb-2">0</div>
          <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium">Bytes transmitted to us</div>
        </div>
      </div>

      <div class="reveal reveal-delay-4 mt-10 text-center">
        <a href="/crisp/privacy" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-dim)] transition-colors link-underline">
          Read the full Crisp privacy policy
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Install / CTA -->
  <section id="install" class="py-24 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="reveal p-10 md:p-14 rounded-2xl bg-[var(--color-text-primary)] text-white relative overflow-hidden">
        <div class="absolute w-80 h-80 rounded-full bg-[var(--color-accent)] opacity-20 blur-3xl -top-20 -right-20"></div>
        <div class="relative z-10">
          <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-white/60 mb-4 block">Install</span>
          <h2 class="font-serif text-3xl md:text-5xl font-medium leading-tight mb-5">Your next AI reply will sound like you, not like ChatGPT.</h2>
          <p class="text-white/70 leading-relaxed mb-8 max-w-xl">Crisp is currently in closed beta. The Chrome Web Store version is under review. Email us to join the beta list.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href={`mailto:${config.email}?subject=Crisp beta access`} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-white text-[var(--color-text-primary)] text-sm font-medium tracking-wide transition-all hover:scale-[1.02]">
              Request beta access
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
            <a href="/crisp/privacy" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-white/20 text-white text-sm font-medium tracking-wide transition-all hover:border-white/40">
              Privacy policy
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="reveal mb-10">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">FAQ</span>
        <h2 class="font-serif text-3xl md:text-4xl font-medium">Questions we already hear</h2>
      </div>

      <div class="space-y-6">
        {[
          { q: "Do I need a new ChatGPT subscription?", a: "No. Crisp uses your existing account — ChatGPT, Claude, Copilot, Perplexity, whichever you already use. We don't charge and don't need access to your AI account." },
          { q: "Does anything about my company go off-device?", a: "No. Crisp runs entirely in your browser. No data is transmitted to us or to any third party. Every setting, including the 'company brain' text, lives in chrome.storage.local on your machine." },
          { q: "Can I disable it?", a: "Yes. One click in the toolbar card and Crisp is off. You can also disable only the system-prompt injection, only the output filter, or only the toolbar." },
          { q: "Can I install it for my whole team?", a: "Yes — during beta, via a shared ZIP and Developer mode install. Once Crisp ships on the Chrome Web Store and Edge Add-ons, one click installs it for each team member. Custom company configurations and onboarding workshops are available — email us." },
        ].map(item => (
          <div class="reveal p-6 rounded-xl bg-white border border-[var(--color-border)]">
            <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">{item.q}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
