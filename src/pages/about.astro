---
import Layout from "../layouts/Layout.astro";
import { config } from "../config";

const principles = [
  {
    title: "Build Once, Scale Infinitely",
    description: "Every product is engineered for autonomous operation. We design systems that compound in value without proportional increases in effort or cost.",
  },
  {
    title: "AI-Augmented Operations",
    description: "We leverage a multi-agent AI stack to plan, build, and ship at speeds typically reserved for much larger organisations. Human judgement guides every decision.",
  },
  {
    title: "Revenue-First Mindset",
    description: "Every venture is evaluated by its proximity to revenue. We ship on marketplaces where buyers already exist, and we optimise for margin over vanity.",
  },
  {
    title: "Lean by Design",
    description: "Local infrastructure, cost-conscious tooling, and compound automation. We run a holding company on the operational overhead of a solo operation.",
  },
];

const timeline = [
  { year: "2026", event: "Võtting Grupp OÜ registered in Estonia" },
  { year: "2026", event: "First APIs deployed to production" },
  { year: "2026", event: "Digital products portfolio launched across marketplaces" },
  { year: "2026", event: "E-commerce operations division established" },
  { year: "2026", event: "AI research and trading systems development initiated" },
];
---

<Layout title="About" description="Learn about Võtting Grupp OÜ — a Tallinn-based holding company building the future of digital commerce.">
  <!-- Hero -->
  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">About Us</span>
          <h1 class="font-serif text-4xl md:text-5xl font-medium leading-tight">
            A new kind of holding company
          </h1>
        </div>
        <div class="reveal reveal-delay-2">
          <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">
            {config.legalName} is a Tallinn-based holding company that builds, operates, and invests in digital ventures.
            We combine artificial intelligence, modern engineering, and lean operations to create businesses
            that scale efficiently across global markets.
          </p>
          <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">
            Our portfolio spans enterprise software, digital products, e-commerce operations, professional services,
            and AI research — all operated from Estonia with distribution across international marketplaces.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal mb-14">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-gold)] mb-4 block">Principles</span>
        <h2 class="font-serif text-3xl md:text-4xl font-medium">How We Operate</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {principles.map((p, i) => (
          <div class={`reveal reveal-delay-${i + 1} p-8 rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-border)] border-glow`}>
            <div class="flex items-start gap-5">
              <div class="text-2xl font-serif text-[var(--color-accent)] opacity-60 mt-0.5 shrink-0">
                0{i + 1}
              </div>
              <div>
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-2">{p.title}</h3>
                <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{p.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 border-t border-[var(--color-border)]">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="reveal mb-14">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">Timeline</span>
        <h2 class="font-serif text-3xl md:text-4xl font-medium">Our Journey</h2>
      </div>

      <div class="space-y-0">
        {timeline.map((item, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 5)} flex gap-8 py-6 ${i < timeline.length - 1 ? "border-b border-[var(--color-border)]" : ""}`}>
            <div class="text-sm font-mono text-[var(--color-text-muted)] w-16 shrink-0 pt-0.5">{item.year}</div>
            <div class="text-[var(--color-text-secondary)] leading-relaxed">{item.event}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Legal Entity Info -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="reveal p-8 rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-border)]">
          <h3 class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium mb-3">Legal Entity</h3>
          <p class="text-[var(--color-text-primary)] font-medium">{config.legalName}</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">{config.registry}</p>
        </div>
        <div class="reveal reveal-delay-1 p-8 rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-border)]">
          <h3 class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium mb-3">Headquarters</h3>
          <p class="text-[var(--color-text-primary)] font-medium">{config.location}</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">European Union</p>
        </div>
        <div class="reveal reveal-delay-2 p-8 rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-border)]">
          <h3 class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium mb-3">Contact</h3>
          <a href={`mailto:${config.email}`} class="text-[var(--color-accent)] hover:text-[var(--color-text-primary)] transition-colors">
            {config.email}
          </a>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">Response within 24 hours</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
