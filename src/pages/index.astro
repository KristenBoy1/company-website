---
import Layout from "../layouts/Layout.astro";
import { config } from "../config";

const verticals = [
  { label: "Software", count: 3 },
  { label: "Commerce", count: 3 },
  { label: "Services", count: 1 },
  { label: "Research", count: 1 },
];

const stats = [
  { value: "8", suffix: "+", label: "Active Ventures" },
  { value: "9", suffix: "+", label: "APIs Deployed" },
  { value: "40", suffix: "+", label: "Digital Products" },
  { value: "2026", suffix: "", label: "Founded" },
];
---

<Layout>
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-grid">
    <!-- Ambient light -->
    <div class="glow-orb w-[600px] h-[600px] bg-[var(--color-accent)] top-[-200px] left-1/2 -translate-x-1/2 opacity-[0.06]" data-parallax></div>
    <div class="glow-orb w-[400px] h-[400px] bg-[var(--color-gold)] bottom-[-100px] right-[-100px] opacity-[0.06]"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-24 text-center">
      <!-- Overline -->
      <div class="reveal mb-8">
        <span class="inline-block text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-text-muted)] border border-[var(--color-border-light)] rounded-full px-5 py-2">
          {config.legalName} &middot; {config.location}
        </span>
      </div>

      <!-- Main heading -->
      <h1 class="reveal reveal-delay-1 font-serif text-5xl md:text-7xl lg:text-8xl font-medium leading-[1.05] tracking-tight max-w-5xl mx-auto">
        <span class="gradient-text">Building the Future</span><br />
        <span class="text-[var(--color-text-primary)]">of Digital Commerce</span>
      </h1>

      <!-- Subtitle -->
      <p class="reveal reveal-delay-2 mt-8 text-lg md:text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed font-light">
        We invest in, build, and operate ventures across software, digital products, e-commerce, and artificial intelligence.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-delay-3 mt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/ventures"
          class="group inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium tracking-wide transition-all hover:shadow-lg hover:scale-[1.02]"
        >
          Our Ventures
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-[var(--color-border-light)] text-[var(--color-text-secondary)] text-sm font-medium tracking-wide transition-all hover:border-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]"
        >
          About the Group
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="reveal reveal-delay-5 mt-24 flex flex-col items-center gap-2">
        <span class="text-[10px] tracking-[0.25em] uppercase text-[var(--color-text-muted)]">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-[var(--color-text-muted)] to-transparent animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Verticals overview -->
  <section class="relative py-28 border-t border-[var(--color-border)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <!-- Left: heading -->
        <div class="reveal">
          <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">What We Do</span>
          <h2 class="font-serif text-3xl md:text-5xl font-medium leading-tight">
            A diversified portfolio of digital ventures
          </h2>
          <p class="mt-6 text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
            From enterprise APIs to consumer products, our ventures span the full spectrum of digital commerce.
            Each operates independently while sharing infrastructure, intelligence, and operational expertise.
          </p>
          <a href="/ventures" class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-dim)] transition-colors link-underline">
            Explore all ventures
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <!-- Right: vertical cards -->
        <div class="grid grid-cols-2 gap-4">
          {verticals.map((v, i) => (
            <div class={`reveal reveal-delay-${i + 1} p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border)] border-glow card-shine`}>
              <div class="text-3xl font-serif font-medium text-[var(--color-text-primary)] mb-1">
                {v.count}
              </div>
              <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium">
                {v.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured ventures -->
  <section class="relative py-28 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] bg-noise">
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-16">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4 block">Portfolio</span>
        <h2 class="font-serif text-3xl md:text-5xl font-medium">Our Ventures</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {config.ventures.map((venture, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} group p-7 rounded-xl bg-white border border-[var(--color-border)] border-glow card-shine shadow-sm`}>
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-300">
                  {venture.name}
                </h3>
                <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium">
                  {venture.vertical}
                </span>
              </div>
              <span class:list={[
                "text-[10px] tracking-wider uppercase font-medium px-3 py-1 rounded-full",
                venture.status === "Operational" ? "bg-emerald-50 text-emerald-600" :
                venture.status === "Active" ? "bg-violet-50 text-[var(--color-accent)]" :
                "bg-amber-50 text-[var(--color-gold)]"
              ]}>
                {venture.status}
              </span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              {venture.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 border-t border-[var(--color-border)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
        {stats.map((stat, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <div class="text-4xl md:text-5xl font-serif font-medium text-[var(--color-text-primary)]" data-count={stat.value} data-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <div class="text-[11px] tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-medium mt-3">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy band -->
  <section class="py-24 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal">
        <span class="text-[11px] font-medium tracking-[0.3em] uppercase text-[var(--color-gold)] mb-6 block">Philosophy</span>
        <blockquote class="font-serif text-2xl md:text-4xl font-medium leading-snug text-[var(--color-text-primary)] italic">
          "Build once, distribute everywhere, automate relentlessly."
        </blockquote>
        <p class="mt-8 text-[var(--color-text-secondary)] max-w-xl mx-auto leading-relaxed">
          We combine artificial intelligence, modern engineering, and lean operations to build
          ventures that scale without proportional effort. Every product we create is designed
          to compound in value over time.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-28 border-t border-[var(--color-border)] overflow-hidden">
    <div class="glow-orb w-[500px] h-[500px] bg-[var(--color-accent)] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-[0.04]"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal">
        <h2 class="font-serif text-3xl md:text-4xl font-medium mb-5">Let's Build Something Together</h2>
        <p class="text-[var(--color-text-secondary)] mb-10 max-w-lg mx-auto leading-relaxed">
          Whether you're looking for custom software, partnership opportunities, or want to learn more about our ventures.
        </p>
        <a
          href="/contact"
          class="group inline-flex items-center justify-center gap-2 px-10 py-4 rounded-full border border-[var(--color-border-light)] text-[var(--color-text-primary)] text-sm font-medium tracking-wide transition-all hover:bg-[var(--color-text-primary)] hover:text-white hover:scale-[1.02]"
        >
          Get in Touch
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
